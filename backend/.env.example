# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finmonitor
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Cache (Redis)
# Leave unset to disable caching (app still works, uncached)
# Local: redis://localhost:6379/0 | Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# API Keys - Data Providers
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_newsapi_key

# Notifications
PAGERDUTY_API_KEY=your_pagerduty_key
PAGERDUTY_SERVICE_ID=your_service_id
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=alerts@yourdomain.com

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# Provider selection
# IPO_PROVIDER: "alphavantage" (free, default) | "finnhub" (premium $130+/mo)
IPO_PROVIDER=alphavantage

# Scheduler
NEWS_POLL_INTERVAL_SECONDS=60
IPO_POLL_INTERVAL_SECONDS=3600
QUOTES_POLL_INTERVAL_SECONDS=30

# Auth (Google OAuth + JWT)
# Get GOOGLE_CLIENT_ID from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# Threshold alerts
ALERTS_REQUIRE_PREMIUM=false    # set true to restrict alerts to premium users
ALERT_COOLDOWN_MINUTES=60       # min minutes between re-firing same alert
