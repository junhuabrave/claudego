# AWS Deploy — required environment variables
# Copy to deploy/aws/.env and fill in values, or export before running deploy.sh
#
# Usage:
#   cp deploy/aws/.env.example deploy/aws/.env
#   # edit .env
#   set -a && source deploy/aws/.env && set +a
#   bash deploy/aws/deploy.sh

# ── AWS account ───────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# ── ECS cluster ───────────────────────────────────────────────────────────────
CLUSTER_NAME=finmonitor
SERVICE_NAME=finmonitor-service
TASK_FAMILY=finmonitor

# ── IAM roles (from AWS Console → IAM → Roles) ────────────────────────────────
# Execution role: allows ECS to pull ECR images and write CloudWatch logs
EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/finmonitor-ecs-execution-role
# Task role: permissions granted to the running container (e.g. Secrets Manager)
TASK_ROLE_ARN=arn:aws:iam::123456789012:role/finmonitor-ecs-task-role

# ── Secrets Manager ARNs (from AWS Console → Secrets Manager) ─────────────────
# Secret containing: database_url
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:finmonitor/db-XXXXXX
# Secret containing: finnhub_api_key, news_api_key, pagerduty_api_key
API_KEYS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:finmonitor/api-keys-XXXXXX

# ── Networking (from AWS Console → VPC → Subnets / Security Groups) ───────────
# Comma-separated, no spaces
SUBNET_IDS=subnet-aaaaaaaa,subnet-bbbbbbbb
SECURITY_GROUP_IDS=sg-cccccccc

# ── ALB target group (from AWS Console → EC2 → Target Groups) ─────────────────
TARGET_GROUP_ARN=arn:aws:elasticloadbalancing:us-east-1:123456789012:targetgroup/finmonitor/XXXXXXXXXXXXXXXX

# ── Application config ────────────────────────────────────────────────────────
# Google OAuth Client ID (Google Cloud Console → APIs & Services → Credentials)
REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# WebSocket URL exposed via CloudFront
REACT_APP_WS_URL=wss://your-cloudfront-domain.cloudfront.net/api/ws
